# ─────────────────────────────────────────────────────────────────────────────
# AYT Group — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to version control.
#
# How to get Firebase values:
#   1. Go to https://console.firebase.google.com
#   2. Select (or create) your project: "aytgroup-com-tr"
#   3. Click the gear icon → Project Settings → General
#   4. Scroll to "Your apps" → Web app → SDK setup → Config
#   5. Copy each value below.
#
# All REACT_APP_ variables are embedded into the JS bundle at build time.
# There are NO runtime secrets here — Firebase security is enforced by
# Firestore Security Rules, not by keeping these keys hidden.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (required) ───────────────────────────────────────────────────────
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Firebase Local Emulator (optional, development only) ──────────────────────
# Set to "true" to connect to the local Firebase emulator suite instead of
# production Firestore / Storage. Run `firebase emulators:start` first.
REACT_APP_USE_FIREBASE_EMULATOR=false

# ── Google Maps (optional) ────────────────────────────────────────────────────
# Currently the map uses a free iframe embed (no API key required).
# If you switch to @react-google-maps/api for advanced features,
# add your key here and update BRAND.mapEmbedUrl in src/constants/index.js.
# REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_key

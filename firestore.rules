rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────

    // Any authenticated user is treated as admin.
    // Firebase Auth accounts are managed manually (console only), so this is safe.
    function isAdmin() {
      return request.auth != null;
    }

    // Validate an incoming contact form submission.
    function isValidContact() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'email', 'subject', 'message', 'status', 'createdAt'])
          && d.name    is string  && d.name.size()    > 0 && d.name.size()    <= 100
          && d.email   is string  && d.email.size()   > 0 && d.email.size()   <= 200
          && d.subject is string  && d.subject.size() > 0 && d.subject.size() <= 200
          && d.message is string  && d.message.size() > 0 && d.message.size() <= 5000
          && d.status  == 'new';
    }

    // Validate a queued email document for Firebase Trigger Email extension.
    // Only allow a mail document if it mirrors an existing contact submission.
    function isValidContactMail(mailId) {
      let d = request.resource.data;
      let contactPath = /databases/$(database)/documents/contacts/$(d.contactId);
      return d.keys().hasAll([
            'to',
            'message',
            'contactId',
            'contactName',
            'contactEmail',
            'contactSubject',
            'contactMessage',
            'createdAt'
          ])
          && d.to is list
          && d.to.size() == 1
          && d.to[0] == 'info@aytgrup.com'
          && d.message is map
          && d.message.keys().hasAll(['subject', 'text'])
          && d.message.subject is string
          && d.message.subject.size() > 0
          && d.message.subject.size() <= 250
          && d.message.text is string
          && d.message.text.size() > 0
          && d.message.text.size() <= 10000
          && d.contactId is string
          && d.contactId == mailId
          && d.contactName is string
          && d.contactEmail is string
          && d.contactSubject is string
          && d.contactMessage is string
          && exists(contactPath)
          && get(contactPath).data.name == d.contactName
          && get(contactPath).data.email == d.contactEmail
          && get(contactPath).data.subject == d.contactSubject
          && get(contactPath).data.message == d.contactMessage;
    }

    // Validate an incoming review submission.
    function isValidReview() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'rating', 'body', 'approved', 'createdAt'])
          && d.name   is string  && d.name.size()  > 0 && d.name.size()  <= 100
          && d.body   is string  && d.body.size()  > 0 && d.body.size()  <= 2000
          && d.rating is number  && d.rating >= 1       && d.rating <= 5
          && d.approved == false;
    }

    // ── Projects ──────────────────────────────────────────────────────────────
    // Public: read-only  |  Admin: full CRUD
    match /projects/{id} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── Services ──────────────────────────────────────────────────────────────
    // Public: read-only  |  Admin: full CRUD
    match /services/{id} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    // Public: read-only (client must filter approved == true)
    // Anyone: create (new reviews are always unapproved)
    // Admin:  full CRUD (approve / delete)
    match /reviews/{id} {
      allow read:   if true;
      allow create: if isValidReview();
      allow update,
            delete: if isAdmin();
    }

    // ── Contacts ──────────────────────────────────────────────────────────────
    // Anyone: create (public contact form — always starts as "new")
    // Admin:  read, update status, delete
    match /contacts/{id} {
      allow create: if isValidContact();
      allow read,
            update,
            delete: if isAdmin();
    }

    // ── Mail Queue (Firebase Trigger Email extension) ─────────────────────────
    // Public: create-only, but strictly tied to an existing contact document.
    // Admin:  read/update/delete
    match /mail/{id} {
      allow create: if isValidContactMail(id);
      allow read,
            update,
            delete: if isAdmin();
    }

    // ── Settings ──────────────────────────────────────────────────────────────
    // Public: read-only  |  Admin: full CRUD
    match /settings/{id} {
      allow read:   if true;
      allow write:  if isAdmin();
    }
  }
}
